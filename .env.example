# Vite Client Environment Variables
# Copy this file to .env.local for local development
# NOTE: In production (Vercel), set these as Environment Variables in project settings

# OpenAI API Key for RAG chatbot (must be prefixed with VITE_ for client-side access)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Pinecone API key and index configuration
# Used by create-index script (Node.js) and client-side vector search
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=terminalportfolio

# Pinecone index host (output after running npm run create-index)
# This is required for client-side vector search
VITE_PINECONE_INDEX_HOST=your-index-host.pinecone.io
VITE_PINECONE_API_KEY=your-pinecone-api-key-here
